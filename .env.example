# ============================================================
# RAVENSPIRE environment variables
# Copy to .env.local and fill in. NEXT_PUBLIC_ vars are exposed
# to the browser; everything else stays server-side only.
# ============================================================

# --- The Archives: Supabase (required, have it) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- The Raven's Mind: Anthropic (required, have it) ---
ANTHROPIC_API_KEY=

# --- The Gatehouse: auth and wallets ---
# Privy (privy.io, free tier): embedded non-custodial wallets + X login
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# X / Twitter OAuth app (developer.x.com, free tier)
X_CLIENT_ID=
X_CLIENT_SECRET=
# WalletConnect / Reown project (cloud.reown.com, free)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- EVM Sight: chain data ---
# Alchemy (alchemy.com, free tier): ETH + L2 RPC and data
ALCHEMY_API_KEY=
# Helius (helius.dev, free tier): Solana
HELIUS_API_KEY=

# --- Market Sight: prices and markets ---
# Birdeye (birdeye.so, free tier)
BIRDEYE_API_KEY=
# CoinGecko demo key (coingecko.com, free)
COINGECKO_API_KEY=
# DexScreener and GeckoTerminal are keyless, nothing needed

# --- Portfolio: GoldRush / Covalent (goldrush.dev, free tier) ---
GOLDRUSH_API_KEY=

# --- The Exchange: in-app trading + swap (EVM only, non-custodial) ---
# 0x Swap API (0x.org): quotes + calldata for buy/sell/swap. Server-side only.
ZEROX_API_KEY=
# Treasury 0x address that collects the 0.5% platform fee via 0x swapFee params.
# Absent, trades are quoted and executed with NO fee attached (never misrouted).
PLATFORM_FEE_RECIPIENT=
# MoonPay on-ramp (moonpay.com): "Top up with card". Publishable key is exposed
# to the browser; the secret signs the widget URL server-side.
NEXT_PUBLIC_MOONPAY_KEY=
MOONPAY_SECRET_KEY=

# --- The Watch: token safety ---
# GoPlus Security (gopluslabs.io, free tier)
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=
# honeypot.is is keyless, nothing needed

# --- The Rookery: live audio and video ---
# LiveKit Cloud (livekit.io, free tier)
NEXT_PUBLIC_LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Ravens: notifications ---
# Telegram bot via @BotFather (free)
TELEGRAM_BOT_TOKEN=
# Resend transactional email (resend.com, free tier)
RESEND_API_KEY=
